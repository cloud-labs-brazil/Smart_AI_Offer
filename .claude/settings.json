{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(pnpm install*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm build*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm exec*)",
      "Bash(turbo *)",
      "Bash(pytest *)",
      "Bash(uv run *)",
      "Bash(uv sync*)",
      "Bash(alembic *)",
      "Bash(python -m alembic *)",
      "Bash(uvicorn *)",
      "Bash(docker compose config*)",
      "Bash(docker compose build*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(make *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(tree *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:files.pythonhosted.org)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(kubectl *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(psql *)",
      "Bash(dropdb *)",
      "Bash(rm -rf *)",
      "Bash(docker system prune*)",
      "Bash(docker compose exec *)",
      "Bash(docker compose run *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/**)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(sudo *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "docker"
    ],
    "filesystem": {
      "denyRead": [
        "~/.aws/credentials",
        "~/.ssh"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org"
      ],
      "allowLocalBinding": true
    }
  },
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "high"
  }
}
