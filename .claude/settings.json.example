{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash(pnpm install*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm build*)",
      "Bash(pnpm typecheck*)",
      "Bash(turbo *)",
      "Bash(docker compose *)",
      "Bash(pytest *)",
      "Bash(uv run *)",
      "Bash(alembic *)",
      "Bash(python -m alembic *)",
      "Bash(uvicorn *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:files.pythonhosted.org)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(kubectl *)",
      "Bash(terraform apply *)",
      "Bash(psql *)",
      "Bash(dropdb *)",
      "Bash(rm -rf *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)"
    ],
    "defaultMode": "acceptEdits"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [
      "docker"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org"
      ],
      "allowLocalBinding": true
    }
  }
}
