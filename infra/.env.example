# Smart Offer — Environment Variables
# Copy to .env and populate with real values
# @see .claude/rules/07-quality-security-devops.md (secrets via env vars only)
# @see infra/docker-compose.yml

# ──── Database ────────────────────────────────────
POSTGRES_DB=smartoffer
POSTGRES_USER=smartoffer
POSTGRES_PASSWORD=changeme
DB_PORT=5432

# ──── Backend API ─────────────────────────────────
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://smartoffer:changeme@localhost:5432/smartoffer
LOG_LEVEL=info
CORS_ORIGINS=["http://localhost:3000"]

# ──── Frontend ────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ──── AI / Gemini ─────────────────────────────────
# WARNING: Client-side exposure in dev only; proxy via backend in production
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=

# ──── Allocation Rules ────────────────────────────
# Default participant weight (0.10 = 10%)
# Only modifiable by SYSTEM_ADMIN role
PARTICIPANT_WEIGHT=0.10
